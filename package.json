  "description": "Herramienta para obtener datos de inmobiliarias en Argentina desde Google Maps y otras fuentes",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "scrape:google": "node src/scrapers/googlePlacesScraper.js",
